runner_enabled      = true
github_owner        = "your-github-owner"
github_repository   = "agent-hub"
github_runner_group = ""
# Leave runner_name unset to default to persistent random_pet naming.
# runner_name       = "github-runner-quiet-otter"
runner_labels       = ["shared", "production"]

# Pulled from Bitwarden and GitHub CLI by scripts/with-runner-secrets.sh
# hcloud_token         = "<sensitive>"
# github_runner_token  = "<sensitive>"
# cloudflare_api_token = "<sensitive>"

# Pulled from terraform-home-network/.env or agent-hub/.env by scripts/with-runner-secrets.sh
# cloudflare_account_id = "<account-id>"
# cloudflare_zone_id    = "<zone-id>"

hcloud_location      = "nbg1"
hcloud_server_type   = "cax11"
hcloud_image         = "ubuntu-24.04"

attic_domain             = "attic.vslice.net"
attic_cache_name         = "github-actions"
attic_cache_public       = true
attic_local_port         = 8080
# cloudflare_tunnel_name = "github-runner-attic"
# r2_bucket_name         = "internal-r2-bucket-name"

# Optional SSH access for maintenance; required when the bootstrap host needs to be reachable.
# admin_cidrs            = ["203.0.113.10/32"]
# ssh_private_key_path   = "~/.ssh/ezra-device-access"
# ssh_authorized_keys    = ["ssh-ed25519 AAAA..."]
