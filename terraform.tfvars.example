runner_enabled      = true
registration_mode   = "github-provider"
registration_scope  = "repository"
github_owner        = "your-github-owner"
github_repository   = "nix-config"
github_repositories = []
github_runner_group = "Default"
runner_name         = "agent-hub-hetzner-arm"
runner_labels       = ["nix-config"]

# Hetzner-only baseline for this repository.

# Pulled from Bitwarden and typically injected as TF_VAR_hcloud_token
# hcloud_token = "<sensitive>"

hcloud_location      = "nbg1"
hcloud_server_type   = "cax21"       # ARM 4 vCPU / 8 GB
hcloud_image         = "nixos-runner-hetzner-image"  # custom image or snapshot name/ID
runner_image_family  = "nixos"
hcloud_volume_size_gb = 100
workspace_volume_size_gb = 200
workspace_mount_path     = "/srv/workspaces"
attic_enabled            = true
attic_domain             = "attic.vslice.net"
attic_endpoint_scheme    = "https"
attic_port               = 443
attic_cache_name         = "github-actions"
attic_cache_public       = false
attic_pull_token_validity = "1y"
attic_ci_token_validity  = "1y"

# Optional SSH access for maintenance.
# admin_cidrs = ["203.0.113.10/32"]
# ssh_authorized_keys = ["ssh-ed25519 AAAA..."]

# Vault mode (avoid storing long-lived GitHub token in Terraform state)
# registration_mode         = "vault-token"
# vault_addr                = "https://vault.vslice.net:8200"
# vault_namespace           = "admin"
# vault_bootstrap_token     = "hvs.xxxxx"  # short TTL token preferred
# vault_runner_secret_mount = "mcp-kv"
# vault_runner_secret_name  = "github/runner-bootstrap"
# vault_runner_secret_key   = "GITHUB_TOKEN"
# attic_vault_secret_mount  = "mcp-kv"
# attic_vault_secret_name   = "github/runner-attic"
# attic_vault_secret_key    = "ATTIC_SERVER_TOKEN_RS256_SECRET_BASE64"

# Optional policy bootstrap
# enable_vault_bootstrap_policy = true
